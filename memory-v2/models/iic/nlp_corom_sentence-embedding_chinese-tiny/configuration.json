{
    "framework": "pytorch",
    "task": "sentence-embedding",
    "dataset": {
        "train": {
            "query_sequence": "query",
            "pos_sequence": "positive_passages",
            "neg_sequence": "negative_passages",
            "text_fileds": [
                "text"
            ],
            "qid_field": "text_id",
            "neg_sample": 8,
            "pretokenized": true
        },
        "valid": {
            "query_sequence": "query",
            "pos_sequence": "positive_passages",
            "neg_sequence": "negative_passages",
            "text_fileds": [
                "text"
            ],
            "qid_field": "query_id",
            "pretokenized": true
        }
    },
    "preprocessor": {
        "type": "sentence-embedding"
    },
    "model": {
        "type": "bert",
        "architectures": [
            "BertForSequenceClassification"
        ],
        "attention_probs_dropout_prob": 0.1,
        "directionality": "bidi",
        "hidden_act": "gelu",
        "hidden_dropout_prob": 0.1,
        "hidden_size": 256,
        "initializer_range": 0.02,
        "intermediate_size": 1024,
        "max_position_embeddings": 512,
        "num_attention_heads": 4,
        "num_hidden_layers": 4,
        "pooler_fc_size": 768,
        "pooler_num_attention_heads": 12,
        "pooler_num_fc_layers": 3,
        "pooler_size_per_head": 128,
        "pooler_type": "first_token_transform",
        "type_vocab_size": 2,
        "vocab_size": 21128
    },
    "train": {
        "use_fp16": true,
        "max_epochs": 10,
        "dataloader": {
            "batch_size_per_gpu": 16,
            "workers_per_gpu": 8
        },
        "optimizer": {
            "type": "AdamW",
            "lr": 3e-05,
            "weight_decay": 0.01
        },
        "lr_scheduler": {
            "type": "StepLR",
            "step_size": 5
        },
        "hooks": [
            {
                "type": "IterTimerHook"
            },
            {
                "type": "CheckpointHook",
                "interval": 1000,
                "by_epoch": false
            },
            {
                "type": "BestCkptSaverHook",
                "save_file_name": "best_model.pt",
                "metric_key": "mrr@10",
                "rule": "max"
            },
            {
                "type": "EvaluationHook",
                "by_epoch": false,
                "interval": 1000
            },
            {
                "type": "TextLoggerHook",
                "interval": 50
            }
        ]
    },
    "evaluation": {
        "dataloader": {
            "batch_size_per_gpu": 2,
            "workers_per_gpu": 1,
            "shuffle": false
        },
        "metrics": [
            "mrr@10"
        ]
    },
    "pipeline": {
        "type": "sentence-embedding"
    },
    "allow_remote": true
}